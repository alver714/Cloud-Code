# --- Telegram ---
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=
# Кто может пользоваться ботом (Telegram user id, через запятую)
ALLOWED_USER_IDS=

# --- Auth движков ---
# Нужен только на headless-VM: сгенерируй локально командой `claude setup-token`.
# На macOS оставь пустым — Claude Code использует Keychain.
CLAUDE_CODE_OAUTH_TOKEN=
# Codex берёт auth из ~/.codex/auth.json (копируется скриптом deploy/03-push-auth.sh)

# --- Пути ---
WORKSPACES_DIR=~/workspaces
SESSIONS_FILE=~/.coding-bot/sessions.json
LOGS_DIR=~/logs

# --- Движки ---
DEFAULT_ENGINE=claude
# Рекомендуется sonnet: fable-5 (дефолт CLI) расходует лимиты подписки в ~3.3 раза быстрее
DEFAULT_MODEL_CLAUDE=sonnet
DEFAULT_MODEL_CODEX=
# low|medium|high|xhigh|max. Дефолт CLI — xhigh — сильно раздувает fan-out субагентов
DEFAULT_EFFORT_CLAUDE=medium
# Аварийный предохранитель на один запуск Claude в $ (пусто = без лимита)
MAX_BUDGET_USD_CLAUDE=
MAX_CONCURRENT_RUNS=3

# --- Token Guard (контроль расхода запуска) ---
# "Токены работы" = fresh input + cache creation + output + 0.1 × cache read.
# Мягкий порог: один раз предупредить, когда запуск перевалил за это число (0 = выкл)
GUARD_SOFT_TOKENS=100000
# Жёсткий порог: остановить запуск при превышении. Переопределяется /budget. (0 = выкл)
GUARD_HARD_TOKENS=250000
# Предел шагов агента — страховка, в основном для codex (нет живых токенов). (0 = выкл)
GUARD_MAX_STEPS=200
# Перед стартом: если 5-часовое окно подписки заполнено ≥ этого %, спросить подтверждение (0 = выкл)
GUARD_PREFLIGHT_PCT=90
